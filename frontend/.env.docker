#VITE_API_PATH="http://demo1.abc-app.org"

# NOTE:
# Do not use full domain/IP for API URL when frontend and backend share same ingress.
# Using http://demo1.abc-app.org/api forced requests to always use the domain host,
# and ingress sometimes routed the request to frontend instead of backend.
# That caused frontend to receive HTML instead of JSON and React crashed.
# Using empty path makes API use the same host as the page, so routing stays correct.
VITE_API_PATH=""
